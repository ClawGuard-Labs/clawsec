# syntax=docker/dockerfile:1
# Development & CI toolchain for Akmon.
# Ships everything needed to build the Go daemon, compile the eBPF object,
# and build the React dashboard. This image does NOT run the daemon — loading
# eBPF into the kernel must happen on a real Linux host.
#
# Build once:
#   docker build -t akmon-dev -f Dockerfile.dev .
#
# Use per command:
#   docker run --rm -v "$PWD:/src" -w /src akmon-dev go build ./...
#   docker run --rm -v "$PWD:/src" -w /src akmon-dev make bpf
#   docker run --rm -v "$PWD:/src" -w /src akmon-dev bash -c 'cd ui && npm ci && npm run build'

FROM golang:1.26-bookworm

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        clang \
        llvm \
        libbpf-dev \
        linux-libc-dev \
        bpftool \
        make \
        git \
        curl \
        gnupg \
        pkg-config \
        zlib1g-dev \
        libelf-dev \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /src
