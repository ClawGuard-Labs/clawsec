/var/log/onyx/*.log
/var/log/onyx/*.json {
    daily
    rotate 14
    compress
    delaycompress
    missingok
    notifempty
    create 0640 root root
    sharedscripts
    postrotate
        # signal monitor to reopen log files if running
        systemctl -q is-active onyx && \
            systemctl kill --kill-who=main --signal=SIGUSR1 onyx || true
    endscript
}
