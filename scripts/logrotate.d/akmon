/var/log/akmon/*.log
/var/log/akmon/*.json {
    daily
    rotate 14
    compress
    delaycompress
    missingok
    notifempty
    create 0640 root root
    sharedscripts
    postrotate
        # signal monitor to reopen log files if running
        systemctl -q is-active akmon && \
            systemctl kill --kill-who=main --signal=SIGUSR1 akmon || true
    endscript
}
